    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf .)",
      "Bash(rm -rf ..)",
      "Bash(rm -r /*)",
      "Bash(rm -r /)",
      "Bash(rm -fr *)",
