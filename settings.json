    "defaultMode": "plan"
  },
  "hooks": {
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bd prime"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/skills/exec-plan/scripts/pre-compact-sync.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/hooks/pre-bash.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/hooks/post-edit-write.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bd init --quiet --skip-hooks 2>/dev/null || true",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$HOME/claude-code-boilerplate/scripts/patch-claude-models.sh --check 2>/dev/null || true",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "$HOME/claude-code-boilerplate/scripts/backup-claude-config.sh 2>/dev/null || true",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bd prime"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/taskmaster/hooks/check-completion.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "ls tools/debug-sessions/ 2>/dev/null | head -1 || true",
            "timeout": 3,
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node /Users/barkleesanders/claude-hud/dist/index.js"
  },
  "enabledPlugins": {
    "browserbase@claude-code-plugin": false,
    "typescript-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "codex@openai-codex": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "voiceEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "mcpServers": {
    "financial-datasets": {
      "command": "/opt/homebrew/bin/uv",
      "args": [
        "--directory",
        "/Users/barkleesanders/tools/financial-datasets-mcp",
        "run",
        "server.py"
      ]
    },
    "cloudflare-api": {
      "url": "https://mcp.cloudflare.com/mcp"
    },
    "stitch": {
      "command": "npx",
      "args": [
        "@_davideast/stitch-mcp",
        "proxy"
      ],
      "env": {
        "STITCH_API_KEY": "YOUR_STITCH_API_KEY_HERE"
      }
    }
  },
  "customApiKeyResponsibility": true
}
