      "Bash(sudo rmdir *)",
      "Bash(git clean -fd*)",
      "Bash(git clean -fdx*)",
      "Bash(git reset --hard*)",
      "Bash(git checkout .)",
      "Bash(git restore .)",
      "Bash(git branch -D *)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(dd if=*)",
      "Bash(mkfs*)",
      "Bash(chmod -R 777 /*)",
      "Bash(chown -R * /*)"
    ],
    "ask": [
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(mv * /dev/null)",
      "Bash(git stash drop*)",
      "Bash(git branch -d *)"
    ],
    "defaultMode": "plan"
  },
  "hooks": {
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bd prime"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/skills/exec-plan/scripts/pre-compact-sync.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/hooks/pre-bash.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/hooks/post-edit-write.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bd init --quiet --skip-hooks 2>/dev/null || true",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bd prime"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/taskmaster/hooks/check-completion.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "ls tools/debug-sessions/ 2>/dev/null | head -1 || true",
            "timeout": 3,
            "async": true
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "browserbase@claude-code-plugin": false,
    "typescript-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "mcpServers": {
    "cloudflare-api": {
      "url": "https://mcp.cloudflare.com/mcp"
    }
  }
}
