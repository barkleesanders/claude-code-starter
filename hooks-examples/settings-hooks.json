{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Skills: /debug /carmack /ship /safety-audit'",
            "timeout": 2
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "ls tools/debug-sessions/ 2>/dev/null | head -1 || true",
            "timeout": 3,
            "async": true
          }
        ]
      }
    ]
  }
}
